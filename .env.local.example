# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Your project URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — KEEP SECRET, server-side only
# Used by agent to create client auth users via admin API
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ─── Setup instructions ───────────────────────────────────────────────────────
#
# 1. Copy this file:  cp .env.local.example .env.local
#
# 2. Fill in the values above from your Supabase project.
#
# 3. In Supabase Dashboard → Storage, create ONE bucket called:
#      property-files
#    Set it to PUBLIC so uploaded files have accessible URLs.
#
# 4. Run the SQL migration in Supabase Dashboard → SQL Editor:
#      supabase/migrations/001_initial_schema.sql
#
# 5. Create your first agent account manually in
#    Supabase Dashboard → Authentication → Users → "Add User"
#    Then in SQL Editor run:
#      INSERT INTO client_profiles (user_id, full_name, role)
#      VALUES ('<your-auth-user-id>', 'Your Name', 'agent');
#
# 6. Start the dev server:  npm run dev
#
# ─── Vercel deployment ───────────────────────────────────────────────────────
# Add the three env vars above as Vercel Environment Variables
# (Project Settings → Environment Variables).
# The vercel.json references them as @supabase_url, @supabase_anon_key,
# and @supabase_service_role_key — make sure Vercel secret names match.
